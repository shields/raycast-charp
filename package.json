{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "charp",
  "title": "Charp Character Picker",
  "description": "Unicode character picker with fuzzy search, popularity ranking, and keyboard layout awareness",
  "icon": "icon.png",
  "author": "michael_shields",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "pick-character",
      "title": "Pick Character",
      "description": "Search and insert Unicode characters",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.19",
    "@raycast/utils": "^2.2.5",
    "fast-xml-parser": "^5.5.10"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.1",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "happy-dom": "20.10.1",
    "prettier": "3.8.3",
    "react-dom": "19.2.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "scripts": {
    "prebuild": "npm run generate",
    "build": "ray build -e dist",
    "predev": "npm run generate",
    "dev": "ray develop",
    "lint": "ray lint && prettier --check .",
    "fix-lint": "ray lint --fix && prettier --write .",
    "fmt": "prettier --write .",
    "generate": "npx tsx scripts/generate-data.ts",
    "leipzig": "npx tsx scripts/compute-leipzig-freq.ts",
    "icon": "npx tsx scripts/generate-icon.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run generate",
    "test": "vitest run"
  }
}
