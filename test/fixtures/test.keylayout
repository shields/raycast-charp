<?xml version="1.1" encoding="UTF-8"?>
<!DOCTYPE keyboard SYSTEM "file://localhost/System/Library/DTDs/KeyboardLayout.dtd">
<!--
  Minimal keyboard layout for testing, based on the macOS US layout structure.
  Includes base, shift, option layers and dead keys (acute, grave).
-->
<keyboard group="0" id="-1" name="Test" maxout="2">
    <layouts>
        <layout first="0" last="0" mapSet="main" modifiers="mods"/>
    </layouts>
    <modifierMap id="mods" defaultIndex="3">
        <keyMapSelect mapIndex="0">
            <modifier keys="command?"/>
        </keyMapSelect>
        <keyMapSelect mapIndex="1">
            <modifier keys="anyShift"/>
        </keyMapSelect>
        <keyMapSelect mapIndex="2">
            <modifier keys="caps"/>
        </keyMapSelect>
        <keyMapSelect mapIndex="3">
            <modifier keys="anyOption"/>
        </keyMapSelect>
        <keyMapSelect mapIndex="4">
            <modifier keys="anyShift anyOption"/>
        </keyMapSelect>
    </modifierMap>
    <keyMapSet id="main">
        <!-- Base layer -->
        <keyMap index="0">
            <key code="0" action="a_a"/>
            <key code="1" output="s"/>
            <key code="2" output="d"/>
            <key code="8" output="c"/>
            <key code="14" action="a_e"/>
            <key code="35" output="p"/>
            <key code="49" action="a_space"/>
            <key code="36" output="&#x000D;"/>
        </keyMap>
        <!-- Shift layer -->
        <keyMap index="1">
            <key code="0" action="a_A"/>
            <key code="1" output="S"/>
            <key code="2" output="D"/>
            <key code="8" output="C"/>
            <key code="14" action="a_E"/>
            <key code="35" output="P"/>
            <key code="49" action="a_space"/>
        </keyMap>
        <!-- Caps layer -->
        <keyMap index="2">
            <key code="0" action="a_A"/>
            <key code="1" output="S"/>
            <key code="14" action="a_E"/>
        </keyMap>
        <!-- Option layer -->
        <keyMap index="3">
            <key code="0" output="&#x03B1;"/>
            <key code="8" output="&#x00E7;"/>
            <key code="14" action="dead_acute"/>
            <key code="35" output="&#x03C0;"/>
            <key code="49" action="a_space"/>
        </keyMap>
        <!-- Shift+Option layer -->
        <keyMap index="4">
            <key code="8" output="&#x00C7;"/>
        </keyMap>
    </keyMapSet>
    <actions>
        <action id="dead_acute">
            <when state="none" next="acute"/>
        </action>
        <action id="dead_grave">
            <when state="none" next="grave"/>
        </action>
        <action id="a_a">
            <when state="none" output="a"/>
            <when state="acute" output="&#x00E1;"/>
            <when state="grave" output="&#x00E0;"/>
        </action>
        <action id="a_e">
            <when state="none" output="e"/>
            <when state="acute" output="&#x00E9;"/>
            <when state="grave" output="&#x00E8;"/>
        </action>
        <action id="a_A">
            <when state="none" output="A"/>
            <when state="acute" output="&#x00C1;"/>
            <when state="grave" output="&#x00C0;"/>
        </action>
        <action id="a_E">
            <when state="none" output="E"/>
            <when state="acute" output="&#x00C9;"/>
            <when state="grave" output="&#x00C8;"/>
        </action>
        <action id="a_space">
            <when state="none" output=" "/>
            <when state="acute" output="&#x00B4;"/>
            <when state="grave" output="`"/>
        </action>
    </actions>
    <terminators>
        <when state="acute" output="&#x00B4;"/>
        <when state="grave" output="`"/>
    </terminators>
</keyboard>
