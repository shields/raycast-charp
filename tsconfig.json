{
  "compilerOptions": {
    "target": "ESNext",
    // The extension is bundled by esbuild via `ray build`, so model modules the
    // way the bundler resolves them. Bundler resolution also permits
    // `import.meta` (used in scripts/tests), which NodeNext rejects unless the
    // package is `"type": "module"` — which in turn would require `with { type:
    // "json" }` on the generated JSON imports.
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    // Scripts and tests run through tsx and the extension is esbuild-bundled —
    // both strip types, so keep every .ts free of non-erasable syntax.
    "erasableSyntaxOnly": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "scripts/**/*", "test/**/*"]
}
